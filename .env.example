# ============================================================================
# CLIENT ENVIRONMENT (VITE_ prefix = exposed in browser bundle)
# DO NOT put secrets here with VITE_ prefix
# ============================================================================

# Firebase Configuration (public config — safe to expose)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Emulator (for local development only)
VITE_USE_FIREBASE_EMULATOR=false

# Sentry Error Monitoring DSN (get from sentry.io → Settings → Projects → DSN)
VITE_SENTRY_DSN=

# External APIs (optional)
VITE_RAPIDAPI_KEY=your_rapidapi_key

# ============================================================================
# SERVER ENVIRONMENT (Netlify dashboard → Site Settings → Environment Variables)
# NEVER add these as VITE_ variables — they would be exposed in the browser bundle
# ============================================================================

# Gemini AI Key (FIX #15: must be server-side only via Netlify env, NOT VITE_GEMINI_API_KEY)
# GEMINI_API_KEY=your_gemini_api_key

# Firebase Admin (auto-injected by Firebase when deploying Cloud Functions)
# FIREBASE_PROJECT_ID=saksham-ai-81c3a
# FIREBASE_STORAGE_BUCKET=saksham-ai-81c3a.appspot.com