rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isRecruiter() {
      return isAuthenticated() && request.auth.token.recruiter == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated(); // For displaying public profiles/names
      allow write: if isOwner(userId); // Users can update their own profile
    }

    // Internships Collection
    match /internships/{internshipId} {
      allow read: if true; // Anyone can read internships
      allow create: if isRecruiter(); 
      allow update, delete: if isRecruiter() && resource.data.recruiterId == request.auth.uid;
    }

    // Applications Collection
    match /applications/{applicationId} {
      // Students can read their own, recruiters can read applications for their jobs
      allow read: if isOwner(resource.data.candidateId) || (isRecruiter() && resource.data.recruiterId == request.auth.uid);
      
      // Students can apply (create)
      allow create: if isAuthenticated() && request.resource.data.candidateId == request.auth.uid;
      
      // Only recruiters can update (e.g. status) via backend (but backend bypasses rules). 
      // If we allow client-side updates by recruiters:
      allow update: if isRecruiter() && resource.data.recruiterId == request.auth.uid;
      
      // Allow students to withdraw their own application
      allow delete: if isOwner(resource.data.candidateId);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      // Students can mark as read/delete their own
      allow update, delete: if isOwner(resource.data.userId);
      // System/Recruiter can create (usually via backend, but in case client-side is needed)
      allow create: if isAuthenticated(); 
    }

    // Wishlist Collection
    match /wishlist/{wishlistId} {
      allow read, write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid);
    }
    
    // Points Transactions
    match /points_transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId);
      // Creation should technically only happen via backend, but if client does it temporarily:
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}